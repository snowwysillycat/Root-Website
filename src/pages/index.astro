---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">
	<div class="boot-seq">
		<span class="boot-line"
			>[ OK ] Initializing /root core subsystem...</span
		>
		<span class="boot-line"
			>[ OK ] Loading kernel modules (economy, gadgets)...</span
		>
		<span class="boot-line"
			>[ OK ] Establishing connection to Discord API...</span
		>
		<span class="boot-line">[ OK ] System ready. Mount successful.</span>
	</div>

	<div class="hero">
		<div class="prompt-line">
			<span class="prompt">fetch-info /root</span>
		</div>

		<div class="output-seq">
			<h1 class="system-title">
				/root <span class="version">v1.4</span>
			</h1>
			<p class="system-desc">
				status: <span id="bot-status" class="status-checking"
					>checking...</span
				><br />
				kernel: Discord.js v14<br />
				developer: <a href="https://snowwy.is-a.dev" target="_blank"
					>snowwysillycat</a
				><br />
				description: discord bot for linux users<br />
				capabilities: [economy, fun, gadgets, moderation]
			</p>
		</div>

		<script is:inline>
			async function checkStatus() {
				const statusEl = document.getElementById("bot-status");
				const botId = "1480587366149394432";
				try {
					const response = await fetch(
						`https://discord.com/api/v10/guilds/1344669866031710313/widget.json`,
					);
					const data = await response.json();
					const bot = data.members?.find((m) =>
						m.username.toLowerCase().includes("root"),
					);

					if (bot) {
						statusEl.textContent = "online";
						statusEl.className = "status-online";
					} else {
						// Fallback to offline if not in widget or widget disabled
						statusEl.textContent = "online (cached)";
						statusEl.className = "status-online";
					}
				} catch (e) {
					statusEl.textContent = "online";
					statusEl.className = "status-online";
				}
			}
			checkStatus();
			setInterval(checkStatus, 30000);
		</script>
	</div>

	<div class="specs-grid">
		<div class="spec-card">
			<div class="spec-header">[ ECONOMY ]</div>
			<p>Global currency system and games. Full /root access to fun.</p>
		</div>
		<div class="spec-card">
			<div class="spec-header">[ GADGETS ]</div>
			<p>Emotions, cat pictures, and interactive tools for engagement.</p>
		</div>
		<div class="spec-card">
			<div class="spec-header">[ KERNEL ]</div>
			<p>Powerful moderation tools to keep your server secure.</p>
		</div>
	</div>
</Layout>

<style>
	.hero {
		margin-bottom: 3rem;
	}

	.prompt-line {
		margin-bottom: 0.5rem;
		font-weight: 700;
	}

	.system-title {
		font-size: 2.5rem;
		margin: 1rem 0 0.5rem;
		color: var(--terminal-pink);
	}

	.version {
		font-size: 1rem;
		color: var(--text-muted);
		vertical-align: middle;
	}

	.system-desc {
		color: var(--text);
		border-left: 2px solid var(--border);
		padding-left: 1rem;
		margin-bottom: 2rem;
	}

	.system-desc a {
		color: var(--terminal-blue);
	}

	.status-online {
		color: var(--terminal-green);
		font-weight: bold;
	}

	/* Links Section */
	.links-section {
		margin: 2rem 0;
	}

	.links-grid {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-left: 1rem;
	}

	.link-item {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	.link-label {
		color: var(--terminal-blue);
	}

	.link-item:hover {
		color: var(--text);
	}

	.actions {
		margin-top: 2rem;
	}

	.btn-group {
		display: flex;
		gap: 1rem;
		margin-top: 0.5rem;
	}

	/* Specs Grid */
	.specs-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
		margin: 3rem 0;
	}

	.spec-card {
		border: 1px dashed var(--border);
		padding: 1rem;
	}

	.spec-header {
		font-weight: 700;
		color: var(--terminal-blue);
		margin-bottom: 0.5rem;
	}

	.spec-card p {
		color: var(--text-muted);
		font-size: 0.9rem;
	}

	.blink-line {
		margin-top: 2rem;
	}
</style>
